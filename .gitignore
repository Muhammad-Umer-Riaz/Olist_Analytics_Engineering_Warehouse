# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.python-version

# ─────────────────────────────────────────────────────────────
# Secrets / credentials  (NEVER commit)
# ─────────────────────────────────────────────────────────────
.env
.env.*
.dlt/secrets.toml
secrets.toml
# dbt connection profiles (live in ~/.dbt or are local-only)
profiles.yml
# Snowflake key-pair private keys
*.p8
*.pem

# Local Snowflake key-pair store (private + public keys live here, local only)
/.keys/**
!/.keys/README.md

# ─────────────────────────────────────────────────────────────
# dbt
# ─────────────────────────────────────────────────────────────
target/
dbt_packages/
dbt_modules/
logs/
.user.yml

# ─────────────────────────────────────────────────────────────
# dlt  (local pipeline state / working dirs)
# ─────────────────────────────────────────────────────────────
.dlt/
# Re-include the dlt project's config dir + config.toml, but never its secrets:
!dlt/.dlt/
!dlt/.dlt/config.toml
dlt/.dlt/secrets.toml
*.duckdb

# ─────────────────────────────────────────────────────────────
# Airflow / Astro CLI
# ─────────────────────────────────────────────────────────────
.astro/
airflow_settings.yaml
airflow.db
airflow.cfg
webserver_config.py

# ─────────────────────────────────────────────────────────────
# Data  (gitignored — see data/README.md to download from Kaggle)
# ─────────────────────────────────────────────────────────────
/data/**
!/data/README.md
!/data/raw/
!/data/raw/.gitkeep

# ─────────────────────────────────────────────────────────────
# Power BI  (.pbip project: track the TMDL model + PBIR report as code;
# ignore the binary export and Desktop-local editor cache/settings)
# ─────────────────────────────────────────────────────────────
*.pbix
**/.pbi/

# ─────────────────────────────────────────────────────────────
# Handoff doc (local only)
.handoff.md

# OS / IDE
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
